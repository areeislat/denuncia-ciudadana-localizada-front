# ============================================
# DESIGEO - Variables de Entorno
# ============================================
# Copia este archivo a .env.local y completa con tus valores
# NUNCA commitees .env.local - está en .gitignore
# ============================================

# Backend API
# URL base del servidor backend
VITE_API_URL=http://localhost:3000

# API Key para autenticación
# Obtén esto de tu backend
VITE_API_KEY=your-api-key-here

# Token de autenticación (si usas JWT)
VITE_AUTH_TOKEN=your-auth-token-here

# ============================================
# Mapas (Opcional - si usas Mapbox en lugar de OpenStreetMap)
# ============================================
# VITE_MAPBOX_TOKEN=pk_test_xxxxx

# ============================================
# Base de datos (Solo si necesitas en frontend)
# ============================================
# VITE_DB_HOST=localhost
# VITE_DB_PORT=5432
# VITE_DB_NAME=desigeo

# ============================================
# Configuración de Aplicación
# ============================================
# VITE_APP_ENV=development
# VITE_LOG_LEVEL=debug

# ============================================
# IMPORTANTE
# ============================================
# - Todas las variables deben comenzar con VITE_ para ser accesibles en el cliente
# - Nunca commitees valores reales de producción
# - Usa .env.local para desarrollo local
# - Usa Vercel Dashboard para variables de producción
# - Mantén este archivo (.env.example) actualizado como referencia
